# ─── Auralux X — Environment Configuration ───

# Spotify Developer App Credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Auth Service
AUTH_SERVICE_PORT=4001
SESSION_SECRET=change_this_to_a_random_64_char_string
ENCRYPTION_KEY=change_this_to_a_random_32_char_string
AUTH_COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:3000

# Redis (optional — falls back to in-memory in dev)
REDIS_URL=redis://localhost:6379

# Frontend
NEXT_PUBLIC_AUTH_URL=http://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Services (future)
API_GATEWAY_PORT=4000
MUSIC_SERVICE_PORT=4002
STREAMING_SERVICE_PORT=4003
PLAYLIST_SERVICE_PORT=4004
USER_SERVICE_PORT=4005
NOTIFICATION_SERVICE_PORT=4006
RECOMMENDATION_SERVICE_PORT=4007
HISTORY_SERVICE_PORT=4008
ANALYTICS_SERVICE_PORT=4009
REALTIME_SERVICE_PORT=4010

# Database (future)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auralux

# Kafka (future)
KAFKA_BROKERS=localhost:9092
